# ─────────────────────────────────────────────────────────────
# Clara ZenTrades AI Pipeline — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# n8n credentials (used for docker-compose setup)
N8N_USER=admin
N8N_PASSWORD=clara123

# Timezone (used by n8n scheduler)
TIMEZONE=America/Edmonton

# ── Optional: Notion Task Tracker ─────────────────────────────
# Create a free Notion integration at https://www.notion.so/my-integrations
# Leave blank to use local JSON task tracker instead
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Optional: Retell API (paid tier only) ─────────────────────
# If you have Retell API access, set this to auto-create agents
# If blank, pipeline outputs agent_spec.json for manual import
RETELL_API_KEY=

# ── Storage (optional - defaults to local JSON files) ─────────
# Uncomment and fill if using Supabase free tier
# SUPABASE_URL=
# SUPABASE_KEY=
